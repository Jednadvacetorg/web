<body>
	<script async src="https://events.framer.com/script?v=2" data-fid="756c61683deacd68c84f6ad41844f7431b5b835e4b38475c5c0c96ed42aa67d0" data-no-nt></script>
	<!-- Start of bodyStart -->
    <!-- Snippet: legacy-bodyStart -->
<script>
(async function() {
  // Spanish-speaking LATAM ISO codes
  const latamEs = ['AR','BO','CL','CO','CR','CU','DO','EC','SV','GT','HN','MX','NI','PA','PY','PE','UY','VE'];

  try {
    // Fast endpoint returns plain country code like MX
    const country = (await (await fetch('https://ipapi.co/country/')).text()).trim().toUpperCase();
    console.log('Detected country:', country); // remove after testing

    // Redirect if visitor is in target country and not already on /es
    if (latamEs.includes(country) && !location.pathname.startsWith('/es')) {
      location.replace('/es' + location.pathname + location.search + location.hash);
    }
  } catch(e) {
    console.log('Geo redirect error', e);
  }
})();
</script>

