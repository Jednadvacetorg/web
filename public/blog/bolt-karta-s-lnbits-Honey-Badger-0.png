<script>
(function () {
  "use strict";

  // ===================== CONFIG =====================
  const COOKIE_NAME  = "nav_intro_shown";
  const SELECTORS    = [
    '[data-nav-intro="1"]',
    '#nav-intro',
    '[data-framer-name="NavIntroWrap"]'
  ];
  const OFFSET_PX    = -90;       
  const DURATION_MS  = 600;       
  const EASING       = "ease-out"; 
  const MAX_WAIT_MS  = 3000;      
  // ==================================================

  
  if (window.__navIntroRan__) return;
  window.__navIntroRan__ = true;

  // ---- helpers ----
  function isReloadNavigation() {
    try {
      const entries = performance.getEntriesByType && performance.getEntriesByType("navigation");
      if (entries && entries[0]) return entries[0].type === "reload";
      if (performance && performance.navigation) return performance.navigation.type === 1;
    } catch (_) {}
    return false;
  }

  function getCookie(name) {
    return document.cookie.split("; ").find(r => r.startsWith(name + "="))?.split("=")[1];
  }
  function setCookie(name, value, maxAgeSeconds) {
    document.cookie = name + "=" + encodeURIComponent(value) + "; path=/; max-age=" + maxAgeSeconds;
  }
  function deleteCookie(name) {
    document.cookie = name + "=; Max-Age=0; path=/";
  }

  
  if (isReloadNavigation()) deleteCookie(COOKIE_NAME);

  const hasPlayed = getCookie(COOKIE_NAME) === "1";

  function findTarget() {
    for (const s of SELECTORS) {
      const el = document.querySelector(s);
      if (el) return el;
    }
    return null;
  }

  function waitForTarget(timeout = MAX_WAIT_MS) {
    const now = findTarget();
    if (now) return Promise.resolve(now);

    return new Promise(resolve => {
      const obs = new MutationObserver(() => {
        const el = findTarget();
        if (el) {
          obs.disconnect();
          resolve(el);
        }
      });
      obs.observe(document.documentElement, { childList: true, subtree: true });
      setTimeout(() => {
        obs.disconnect();
        resolve(findTarget());
      }, timeout);
    });
  }

  function setStatic(el) {
    el.style.transition = "none";
    el.style.transform  = "translateY(0px)";
    el.style.willChange = "auto";
  }

  function animateIn(el) {
    
    el.style.transition = "none";
    el.style.transform  = "translateY(" + OFFSET_PX + "px)";
    el.style.willChange = "transform";

    
    requestAnimationFrame(() => {
      if (el.animate) {
        
        const anim = el.animate(
          [
            { transform: "translateY(" + OFFSET_PX + "px)" },
            { transform: "translateY(0px)" }
          ],
          { duration: DURATION_MS, easing: EASING, fill: "forwards" }
        );
        anim.onfinish = () => setStatic(el);
      } else {
        
        el.style.transition = "transform " + DURATION_MS + "ms " + EASING;
        
        void el.offsetWidth;
        el.style.transform = "translateY(0px)";
        setTimeout(() => setStatic(el), DURATION_MS + 20);
      }
    });
  }

  function run() {
    waitForTarget().then(el => {
      if (!el) return;
      if (hasPlayed) {
        
        setStatic(el);
      } else {
        
        animateIn(el);
        setCookie(COOKIE_NAME, "1", 60 * 60 * 24 * 365); 
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", run);
  } else {
    run();
  }
})();
</script>
