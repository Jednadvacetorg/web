<script>

function ff_getReferralCode(queryName) {
  const STORAGE_KEY = 'ff-affiliate-ref';

  const now = Date.now();
  const params = new URLSearchParams(window.location.search);
  let cookie = localStorage.getItem(STORAGE_KEY);
  let ref, expiresAt;

  // get referral code from local storage or if missing use url query
  if (cookie) {
    try {
      const data = JSON.parse(cookie);
      ref = data.ref;
      expiresAt = data.expiresAt;
    } catch (e) {
      ref = params.get(queryName);
    }
  } else {
    ref = params.get(queryName);
  }

  // if referral code doesn't exist or is expired do nothing
  if (!ref || (expiresAt && expiresAt < now)) {
    return null;
  }

  // store referral code in local storage with 30 days expiration
  cookie = JSON.stringify({
    ref,
    expiresAt: now + 30 * 24 * 60 * 60 * 1000,
  });
  localStorage.setItem(STORAGE_KEY, cookie);

  return ref;
}

function ff_getUtmTag(queryName) {
  const storageKey = `ff-${queryName}`;
  const params = new URLSearchParams(window.location.search);

  if (params.has(queryName)) {
    const value = params.get(queryName);
    sessionStorage.setItem(storageKey, value);
    return value;
  }

  return sessionStorage.getItem(storageKey);
}

function ff_main() {
  const APP_URL_HOST = 'app.firefish.io';
  const REF_QUERY_NAME = 'ref';
  const ENTRY_POINT_QUERY_NAME = 'entry_point';
  const UTM_TAG_QUERY_NAMES = [
    'utm_source',
    'utm_medium',
    'utm_campaign',
    'utm_term',
    'utm_content',
    'fbclid',
    'twclid',
    'gclid',
    'msclkid',
    'ttclid',
    'li_fat_id',
    'yclid',
    'sclid',
  ];

  const ref = ff_getReferralCode(REF_QUERY_NAME);

  const tags = UTM_TAG_QUERY_NAMES.map(key => {
    const value = ff_getUtmTag(key);
    return value ? { key, value } : null;
  }).filter(Boolean);

  // get all html link tags <a>
  const links = document.getElementsByTagName('a');

  // update all links href query params
  for (const link of links) {
    try {
      const linkUrl = new URL(link.href);
      const isAppLink = linkUrl.host.includes(APP_URL_HOST);
      const hasRef = linkUrl.searchParams.has(REF_QUERY_NAME);

      const isFileLink =
        /\.(pdf|docx?|xlsx?|pptx?|zip|png|jpg|jpeg|gif|svg)$/i.test(
          linkUrl.pathname
        );

      if (!isFileLink) {
        if (isAppLink && !hasRef && ref) {
          linkUrl.searchParams.set(REF_QUERY_NAME, ref);
        }

        tags.forEach(tag => linkUrl.searchParams.set(tag.key, tag.value));

        linkUrl.searchParams.set(ENTRY_POINT_QUERY_NAME, 'landing_page');

        link.href = linkUrl.href;
      }
    } catch (e) {
      // swallow error
    }
  }
}

(function (history) {
  const pushState = history.pushState;
  history.pushState = function (state) {
    setTimeout(ff_main, 500);
    return pushState.apply(history, arguments);
  };
})(window.history);

setTimeout(ff_main, 2000);

</script>

